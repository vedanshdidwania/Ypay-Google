# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# SUPABASE_URL: Your Supabase project URL.
VITE_SUPABASE_URL="https://grvjeihjpjebnmtwxlgy.supabase.co"

# SUPABASE_ANON_KEY: Your Supabase anonymous API key (Anon Public).
VITE_SUPABASE_ANON_KEY="your-anon-key-here"

# SUPABASE_SERVICE_ROLE_KEY: Your Supabase service role key (Secret Key).
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key-here"

# NOWPayments API Key
NOWPAYMENTS_API_KEY="your-nowpayments-api-key"

# NOWPayments IPN Secret (for webhooks)
NOWPAYMENTS_IPN_SECRET="your-nowpayments-ipn-secret"
